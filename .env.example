# Provider API keys (LangChain wrappers will use these directly)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Transcription stage (audio -> transcript with timestamps)
# Example models: whisper-1, gpt-4o-mini-transcribe, gpt-4o-transcribe
# Optional override (default: openai)
# TRANSCRIBE_PROVIDER=openai
TRANSCRIBE_MODEL=whisper-1
# Optional advanced override (usually leave unset; falls back to OPENAI_API_KEY)
# TRANSCRIBE_API_KEY=

# Segmentation stage (transcript -> JSON modules)
# Examples: gpt-4.1, gpt-4o, o3-mini, claude-3-5-sonnet, gemini-2.0-flash
# Optional override: openai | anthropic | google
# SEGMENT_PROVIDER=
SEGMENT_MODEL=gpt-4.1
SEGMENT_TEMPERATURE=0
# Optional advanced override (usually leave unset; provider key is inferred from SEGMENT_MODEL)
# SEGMENT_API_KEY=

# Local binaries
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Prompt template path for module segmentation
SEGMENT_PROMPT_FILE=prompts/segment_modules_prompt.txt

# Default output root for `run-all`
OUTPUT_ROOT=outputs

# Cut stage rendering defaults
# Path to a PNG/JPG logo that should be overlaid in every clip.
CUT_LOGO_PATH=
# Number of pixels to inset the logo from the top/right edges.
CUT_LOGO_MARGIN=16
# Whether subtitles should be burned into clips (1/true to enable).
CUT_ENABLE_SUBTITLES=1
# Optional font directory for subtitles (ffmpeg `fontsdir` accepts a folder).
CUT_SUBTITLE_FONT_PATH=
# Subtitle appearance (font size in pixels).
CUT_SUBTITLE_FONT_SIZE=26
# Subtitle and outline colors in hex (#RRGGBB).
CUT_SUBTITLE_COLOR=#FFFFFF
CUT_SUBTITLE_OUTLINE_COLOR=#000000
# Outline thickness in pixels.
CUT_SUBTITLE_OUTLINE_WIDTH=3
# Bottom margin for subtitle lines.
CUT_SUBTITLE_MARGIN=40
# Video encoder/quality used in `_render_final_clip`
# Choose a codec: `libx264` (default) or `h264_nvenc`/`hevc_nvenc` when you want GPU acceleration.
CUT_VIDEO_ENCODER=libx264
# Extra encoder arguments (passed as-is). Defaults to medium CRF for CPU.
CUT_VIDEO_ENCODER_ARGS=-preset medium -crf 20
